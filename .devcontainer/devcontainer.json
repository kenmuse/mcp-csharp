{
  "name": "MCP Weather Server",
  "image": "mcr.microsoft.com/devcontainers/base:2.1.7-noble",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "10.0",
      "additionalDotnetVersions": "9.0"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit"
      ],
      "settings": {
        "dotnet.defaultSolution": "src/WeatherServer/WeatherServer.csproj"
      }
    }
  },
  "updateContentCommand": {
    "dotnet" : "dotnet build src/WeatherServer/WeatherServer.csproj",
    "npm" : "npm install -g @modelcontextprotocol/inspector"
  },
  "forwardPorts": [6274, 6277],
  "portsAttributes": {
    "6274": {
      "label": "MCP Inspector UI",
      "onAutoForward": "notify"
    },
    "6277": {
      "label": "MCP Inspector Proxy",
      "onAutoForward": "silent"
    },
    "5000": {
      "label": "MCP",
      "onAutoForward": "notify"
    }
  }
}
