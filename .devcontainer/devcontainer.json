{
  "name": "MCP Weather Server",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-10.0",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "9.0",
      "additionalDotnetVersions": "10.0"
    }
}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit"
      ],
      "settings": {
        "dotnet.defaultSolution": "src/WeatherServer/WeatherServer.csproj"
      }
    }
  },
  "postCreateCommand": {
    "dotnet" : "dotnet build src/WeatherServer/WeatherServer.csproj",
    "npm" : "npm install -g @modelcontextprotocol/inspector"
  },
  "forwardPorts": [6274, 6277],
  "portsAttributes": {
    "6274": {
      "label": "MCP Inspector UI",
      "onAutoForward": "notify"
    },
    "6277": {
      "label": "MCP Inspector Proxy",
      "onAutoForward": "silent"
    },
    "8080": {
      "label": "MCP",
      "onAutoForward": "notify"
    }
  }
}
