{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/WeatherServer/WeatherServer.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "inspect",
      "type": "shell",
      "command": "npx",
      "args": [
        "@modelcontextprotocol/inspector",
        "--transport",
        "http",
        "--server-url",
        "http://127.0.0.1:5000/"
      ],
      "options": {
        "env": {
          "DANGEROUSLY_OMIT_AUTH": "true",
          "HOST": "0.0.0.0",
          "CLIENT_PORT": "6274",
          "SERVER_PORT": "6277"
        }
      },
      "problemMatcher": [],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
